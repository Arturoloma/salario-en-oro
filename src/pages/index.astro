---
import { calculateGoldCoins } from '../lib/calculate';
import { GOLD_COIN_FINE_GOLD_GRAMS } from '../lib/constants';
import calculationData from '../../public/data/calculation-data.json';
import metadata from '../../public/data/metadata.json';

import '../styles/global.css';

const DEFAULT_SALARY_EUR = 1500;
const DEFAULT_PAGAS = 12;

const latestRow = [...calculationData.data].sort((a, b) => b.year - a.year)[0];

if (!latestRow) {
  throw new Error('Calculation data must include at least one row');
}

const goldEurPerGram = latestRow.goldEurPerGram;

if (!Number.isFinite(goldEurPerGram) || goldEurPerGram <= 0) {
  throw new Error(
    'Latest calculation row must include a positive goldEurPerGram',
  );
}

const goldSource = metadata.sources.find((s) => s.id === 'gold');
const ecbSource = metadata.sources.find((s) => s.id === 'eur-usd');

if (!goldSource || !ecbSource) {
  throw new Error('Metadata must include gold and eur-usd sources');
}

const initialMonthlyCoins = calculateGoldCoins(
  DEFAULT_SALARY_EUR,
  goldEurPerGram,
);
const initialAnnualCoins = initialMonthlyCoins * DEFAULT_PAGAS;

const numberFormatter = new Intl.NumberFormat('es-ES', {
  maximumFractionDigits: 2,
});
const coinFormatter = new Intl.NumberFormat('es-ES', {
  maximumFractionDigits: 2,
  minimumFractionDigits: 2,
});
const goldEurFormatter = new Intl.NumberFormat('es-ES', {
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});
const retrievedDateFormatted = new Intl.DateTimeFormat('es-ES', {
  dateStyle: 'long',
  timeZone: 'UTC',
}).format(new Date(`${metadata.retrievedAt}T00:00:00Z`));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Salario en Oro</title>
  </head>
  <body>
    <main class="page-shell calculator-page">
      <p class="eyebrow">Salario en Oro</p>
      <h1>Calcula tu salario en monedas de oro</h1>

      <form
        class="calculator"
        data-gold-eur-per-gram={goldEurPerGram}
        data-gold-coin-fine-gold-grams={GOLD_COIN_FINE_GOLD_GRAMS}
      >
        <div class="field-group">
          <label for="salary">Tu salario neto mensual</label>
          <div class="input-wrap">
            <input
              id="salary"
              name="salary"
              type="number"
              inputmode="decimal"
              min="0"
              step="0.01"
              value={DEFAULT_SALARY_EUR}
            />
            <span aria-hidden="true">€/mes</span>
          </div>
        </div>

        <fieldset class="radio-group" id="pagas-fieldset">
          <legend>Pagas</legend>
          <div class="radio-options">
            <label class="radio-label">
              <input
                type="radio"
                id="pagas-12"
                name="pagas"
                value="12"
                checked
              />
              <span>12 pagas</span>
            </label>
            <label class="radio-label">
              <input type="radio" id="pagas-14" name="pagas" value="14" />
              <span>14 pagas</span>
            </label>
          </div>
        </fieldset>

        <output
          class="result-card"
          id="result"
          for="salary pagas-12 pagas-14"
          aria-live="polite"
          aria-atomic="true"
        >
          <span class="result-text" id="result-text">
            {numberFormatter.format(DEFAULT_SALARY_EUR)} €/mes equivalen a
          </span>
          <strong id="result-value-primary">
            {coinFormatter.format(initialMonthlyCoins)} monedas de oro al mes
          </strong>
          <span id="result-value-secondary" class="result-value-secondary">
            {coinFormatter.format(initialAnnualCoins)} monedas de oro al año
          </span>
        </output>
      </form>

      <section class="trust-section" aria-labelledby="transparencia-titulo">
        <p class="eyebrow">Transparencia</p>
        <h2 id="transparencia-titulo">Transparencia del cálculo</h2>

        <div class="trust-grid">
          <article class="trust-card trust-card--methodology">
            <h3>Metodología</h3>
            <p>
              El cálculo actual convierte tu salario neto mensual en monedas de
              oro usando el precio anual del oro en euros.
            </p>
            <pre><code>monedas mensuales = salario neto mensual / precio anual del oro en €/g / 5,81
monedas anuales = monedas mensuales × pagas</code></pre>
            <p>
              1 moneda de oro = 5,81 gramos de oro fino. Es una referencia
              histórica abstracta inspirada en monedas europeas como las 20
              pesetas, los 20 francos franceses o los 20 francos suizos. No
              representa una moneda legal actual ni una pieza concreta de
              coleccionismo.
            </p>
          </article>

          <article class="trust-card trust-card--data">
            <h3>Datos utilizados</h3>
            <dl class="data-facts">
              <dt>Último año completo</dt>
              <dd>{latestRow.year}</dd>

              <dt>Precio del oro</dt>
              <dd>{goldEurFormatter.format(goldEurPerGram)} €/g</dd>

              <dt>Conjunto de datos obtenido</dt>
              <dd>{retrievedDateFormatted}</dd>

              <dt>Versión de metodología</dt>
              <dd>v{metadata.methodologyVersion}</dd>
            </dl>
          </article>

          <article class="trust-card trust-card--sources">
            <h3>Fuentes</h3>
            <p>Datos usados en el cálculo de esta página:</p>
            <ul class="source-list">
              <li>
                <a
                  href={goldSource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {goldSource.name}
                  <span class="sr-only">(abre en una pestaña nueva)</span>
                </a>
                — precio anual del oro en USD/onza troy (Pink Sheet · datos históricos
                anuales).
              </li>
              <li>
                <a
                  href={ecbSource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {ecbSource.name}
                  <span class="sr-only">(abre en una pestaña nueva)</span>
                </a>
                — tipo de cambio EUR/USD de referencia.
              </li>
            </ul>
            <p>
              Código fuente del proyecto:
              <a
                href="https://github.com/Arturoloma/salario-en-oro"
                target="_blank"
                rel="noopener noreferrer"
              >
                github.com/Arturoloma/salario-en-oro
                <span class="sr-only">(abre en una pestaña nueva)</span>
              </a>
            </p>
          </article>

          <article class="trust-card trust-card--privacy">
            <h3>Privacidad</h3>
            <p>
              El salario que introduces no se envía a ningún servidor. Todo el
              cálculo se ejecuta en tu navegador.
            </p>
            <p>
              En esta versión no hay cuentas de usuario, formularios de envío ni
              cookies de seguimiento.
            </p>
          </article>
        </div>

        <article class="trust-card trust-card--disclaimer">
          <h3>Limitaciones y aviso</h3>
          <ul class="limitation-list">
            <li>
              Se usan medias anuales del precio del oro y del tipo de cambio; no
              son precios intradía en tiempo real.
            </li>
            <li>
              No se incluyen comisiones, impuestos, spreads, costes de custodia
              ni primas de coleccionismo.
            </li>
            <li>
              Esto no es asesoramiento financiero. Es una herramienta educativa
              y de interés público.
            </li>
            <li>
              Las estimaciones se basan en datos históricos anuales y pueden no
              reflejar el valor exacto en un momento concreto.
            </li>
          </ul>
        </article>
      </section>
    </main>

    <script type="module" is:inline>
      const form = document.querySelector('.calculator');
      const salaryInput = document.querySelector('#salary');
      const resultText = document.querySelector('#result-text');
      const resultValuePrimary = document.querySelector(
        '#result-value-primary',
      );
      const resultValueSecondary = document.querySelector(
        '#result-value-secondary',
      );

      if (
        form instanceof HTMLFormElement &&
        salaryInput instanceof HTMLInputElement &&
        resultText &&
        resultValuePrimary &&
        resultValueSecondary
      ) {
        const goldEurPerGram = Number(form.dataset.goldEurPerGram);
        const goldCoinFineGoldGrams = Number(
          form.dataset.goldCoinFineGoldGrams,
        );
        const numberFormatter = new Intl.NumberFormat('es-ES', {
          maximumFractionDigits: 2,
        });
        const coinFormatter = new Intl.NumberFormat('es-ES', {
          maximumFractionDigits: 2,
          minimumFractionDigits: 2,
        });

        const getPagas = () =>
          Number(
            form.querySelector('input[name="pagas"]:checked')?.value ?? '12',
          );

        const clearResult = () => {
          resultText.textContent = '';
          resultValuePrimary.textContent = '';
          resultValueSecondary.textContent = '';
        };

        const updateResult = () => {
          const pagas = getPagas();

          if (salaryInput.value === '') {
            clearResult();
            return;
          }

          const salary = salaryInput.valueAsNumber;

          if (Number.isNaN(salary) || salary < 0) {
            clearResult();
            return;
          }

          const monthlyCoins = salary / goldEurPerGram / goldCoinFineGoldGrams;
          const annualCoins = monthlyCoins * pagas;
          resultText.textContent = `${numberFormatter.format(
            salary,
          )} €/mes equivalen a`;
          resultValuePrimary.textContent = `${coinFormatter.format(
            monthlyCoins,
          )} monedas de oro al mes`;
          resultValueSecondary.textContent = `${coinFormatter.format(
            annualCoins,
          )} monedas de oro al año`;
        };

        form.addEventListener('submit', (event) => event.preventDefault());
        salaryInput.addEventListener('input', updateResult);
        form.querySelectorAll('input[name="pagas"]').forEach((radio) => {
          radio.addEventListener('change', updateResult);
        });
      }
    </script>
  </body>
</html>
